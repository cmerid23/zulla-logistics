# =========================================================
# Zulla Logistics — environment template
# Copy to .env and fill in real values. Never commit .env.
# =========================================================

# ----- Core -----
NODE_ENV=development
PORT=4000
PGSSL=false

# ----- Database (Railway injects DATABASE_URL automatically for the PostgreSQL plugin) -----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zulla

# ----- Auth -----
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_ACCESS_TTL=15m
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=change-me-32-bytes-of-entropy-base64

# ----- AI (OpenAI for rate suggestions + freight assistant) -----
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# ----- Payments -----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ----- Notifications (PWA push + transactional email; no SMS) -----
RESEND_API_KEY=re_xxx
RESEND_FROM=no-reply@zulla.example.com

# Admin escalation target used by jobs (insurance expiry sweep, FMCSA flag).
ADMIN_EMAIL=ops@zulla.example.com

# ----- Storage (Cloudflare R2) -----
CF_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=zulla-docs

# ----- Maps -----
MAPBOX_TOKEN=pk.xxx

# ----- Integrations -----
DAT_API_KEY=
DAT_API_SECRET=
HIGHWAY_API_KEY=
FMCSA_WEBKEY=

# ----- Push Notifications (VAPID) -----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@zulla.example.com

# =========================================================
# Frontend (Vite) — must be prefixed VITE_ to be exposed to the browser.
# =========================================================
VITE_API_URL=http://localhost:4000
VITE_APP_URL=http://localhost:5173
VITE_MAPBOX_TOKEN=pk.xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_VAPID_PUBLIC_KEY=
