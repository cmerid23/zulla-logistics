# Keep pnpm non-interactive in CI / Railway builds. Without this, when nixpacks
# does its second install pass after the source COPY, pnpm sees the existing
# node_modules tree, asks "remove and reinstall?" via a TTY prompt, and the
# build hangs / fails because no TTY is attached.
confirm-modules-purge=false

# Avoid the dynamic engine warning during pnpm install on the build image.
engine-strict=false
